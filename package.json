{
  "name": "volley-main",
  "version": "0.1.0",
  "private": true,
  "description": "Browser smoke-тесты для статического приложения King of the Court.",
  "scripts": {
    "validate:static": "node scripts/validate-static.mjs",
    "prepare:pages": "node scripts/prepare-pages.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:serve": "node serve.mjs 8000",
    "test:unit": "vitest run",
    "test:smoke": "playwright test",
    "test:e2e:thai": "playwright test tests/e2e --reporter=list",
    "test:gate": "node scripts/release-gate.mjs",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "http-server": "^14.1.1",
    "jsdom": "^26.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
